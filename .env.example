# Copy this file to .env and fill in real values.
# .env is gitignored — never commit real secrets.

# AI risk-scoring API key (bring-your-own-key).
# Placeholder only. Put the real key in .env (gitignored), never here.
AI_API_KEY=your-ai-provider-api-key-here

# Session signing secret — any long random string (>= 16 chars; required in production)
SESSION_SECRET=

# Session timing (optional; safe defaults shown)
SESSION_TTL_HOURS=12
SESSION_IDLE_MINUTES=30

# Seeded account usernames (email-style). No signup endpoint exists.
ADMIN_USERNAME=admin123@gmail.com
VIEWER_USERNAME=viewer123@gmail.com

# Seeded account passwords — set STRONG values in production.
# The server refuses to start in production if these are weak/default.
ADMIN_PASSWORD=
VIEWER_PASSWORD=

# Server port
PORT=3000
